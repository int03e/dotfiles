{ pkgs, lib, ... }: # Ensure lib is here

{
  console.font = "${pkgs.terminus_font}/share/consolefonts/ter-v32n.psf.gz";

  boot = {
    loader.grub = {
      enable = true;
      device = "nodev";
      efiSupport = true;
      useOSProber = true;
      gfxmodeEfi = "1920x1080,1280x720,auto";
      gfxpayloadEfi = "keep";
      fontSize = 64;
    };
    consoleLogLevel = 0;

    loader.efi.canTouchEfiVariables = true;
    kernelPackages = pkgs.linuxPackages_latest;

    kernelModules = [
      "tuxedo_keyboard"
      "tuxedo_io"
    ];

    # This global blacklist is inherited by the initrd automatically
    blacklistedKernelModules = [
      "asus_wmi"
      "asus_nb_wmi"
      "clevo_wmi"
      "uniwill_wmi"
    ];

    # The 'hammer' to ensure they never load
    extraModprobeConfig = ''
      options tuxedo_keyboard support_battery_extension=1

      install asus_wmi /run/current-system/sw/bin/false
      install asus_nb_wmi /run/current-system/sw/bin/false
      install clevo_wmi /run/current-system/sw/bin/false
      install uniwill_wmi /run/current-system/sw/bin/false
    '';

    initrd.kernelModules = [ "amdgpu" ];

    kernelParams = [
      "tuxedo_keyboard.support_battery_extension=1"
      "acpi_backlight=native"
      "amdgpu.backlight=0"
      "video.use_native_backlight=1"
      # These MUST be here for systemd-logind to enable the 1-hour timer
      "resume=/dev/disk/by-uuid/2a88ba25-c2ba-48c0-988a-09009ea1efdd"
      "resume_offset=239663104"
      "rtc_cmos.use_acpi_alarm=1"
    ];

    # This is for NixOS internal resume logic
    resumeDevice = "/dev/disk/by-uuid/2a88ba25-c2ba-48c0-988a-09009ea1efdd";
  };

  nixpkgs.overlays = [
    (self: super: {
      tuxedo-drivers = super.tuxedo-drivers.overrideAttrs (oldAttrs: rec {
        version = "4.21.0";
        src = pkgs.fetchFromGitLab {
          owner = "tuxedocomputers/development/packages";
          repo = "tuxedo-drivers";
          rev = "v${version}";
          # NOTE: Nix will show a hash mismatch on the first build.
          # Just copy the 'got:' hash it gives you into this field.
          hash = "sha256-RInT2VfB7nI+7/Nn0mXkUvjG5ZcI0ZfG0mO+yXwL0I8=";
        };
      });
    })
  ];

  # --- Battery & Hardware ---
  hardware.tuxedo-drivers.enable = true;
  hardware.tuxedo-rs = {
    enable = true;
    tailor-gui.enable = true;
  };

  # --- Lid Logic (Forces the 1-hour timer) ---
  services.logind = {
    lidSwitch = lib.mkForce "suspend-then-hibernate";
    lidSwitchExternalPower = lib.mkForce "suspend";
  };

  # --- Sleep/Hibernate Config ---
  systemd.sleep.extraConfig = ''
    HibernateDelaySec=1h
    AllowSuspend=yes
    AllowHibernation=yes
    AllowSuspendThenHibernate=yes
  '';

  # --- Ensure Charging Profile is re-applied on wake ---
  systemd.services.tuxedo-battery-set = {
    description = "Set Tuxedo battery charging profile";
    after = [
      "multi-user.target"
      "post-resume.target"
    ];
    wantedBy = [
      "multi-user.target"
      "post-resume.target"
    ];
    script = ''
      ${pkgs.coreutils}/bin/sleep 5
      if [ -f /sys/devices/platform/tuxedo_keyboard/charging_profile/charging_profile ]; then
        echo "stationary" > /sys/devices/platform/tuxedo_keyboard/charging_profile/charging_profile
      fi
    '';
    serviceConfig.Type = "oneshot";
  };

  # --- Storage ---
  systemd.tmpfiles.rules = [ "d /mnt/media 0755 root root -" ];

  fileSystems."/mnt/media" = {
    device = "/dev/disk/by-uuid/2f8f0bfa-bd2f-435f-a671-b84baade1549";
    fsType = "btrfs";
    options = [
      "defaults"
      "nofail"
      "compress=zstd"
    ];
  };

  swapDevices = [
    {
      device = "/var/lib/swapfile";
      size = 34 * 1024;
    }
  ];
}
